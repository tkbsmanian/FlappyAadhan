# Copy to .env for local development
# Railway sets PORT and RAILWAY_VOLUME_MOUNT_PATH automatically

PORT=3001
NODE_ENV=development

# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:8765,https://your-netlify-app.netlify.app

# Optional: protect analytics endpoints with an API key
# Leave blank to keep analytics open (fine for dev)
ANALYTICS_API_KEY=change-me-in-production

# Railway sets this automatically when a volume is attached
# RAILWAY_VOLUME_MOUNT_PATH=/data
